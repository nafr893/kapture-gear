{{ 'in-production-badge.css' | asset_url | stylesheet_tag }}

{%- assign product_form_id = 'product-form-' | append: product.id | append: '-' | append: section.id -%}

<in-production-badge
  data-form-id="{{ product_form_id }}"
  data-selected-variant-id="{{ product.selected_or_first_available_variant.id }}"
  {{ block.shopify_attributes }}>

  <script type="application/json" data-ipb-variants>
    [
      {%- for variant in product.variants -%}
        {
          "id": {{ variant.id | json }},
          "inventoryPolicy": {{ variant.inventory_policy | json }},
          "inventoryQuantity": {{ variant.inventory_quantity | json }},
          "backorderDate": {{ variant.metafields.custom.backorder_date.value | json }}
        }{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ]
  </script>

  {%- if request.design_mode -%}
    <div class="ipb__editor-placeholder">
      <span>In Production Badge</span>
      <span class="ipb__editor-note">Visible on storefront when selected variant is in production</span>
    </div>
  {%- endif -%}

  <div class="ipb__badge" data-ipb-badge hidden>
    <span class="ipb__label">In Production</span>
    <span class="ipb__date" data-ipb-date></span>
  </div>

</in-production-badge>

<script src="{{ 'in-production-badge.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "In Production Badge",
  "limit": 1,
  "presets": [
    {
      "name": "In Production Badge"
    }
  ]
}
{% endschema %}
